# Copy this file to `.env` and fill in the values you need.

# Required for the default OpenAI-backed workflow.
OPENAI_API_KEY=

# Optional, but useful for Hugging Face downloads if your login is not cached.
HF_TOKEN=

# Optional overrides. The defaults work for local development.
DB_PATH=
PORT=

# The competition API uses decision_making/config/api.yaml by default.
# Edit that file directly if you want to change the analyst workflow.
