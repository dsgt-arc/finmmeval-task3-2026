{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [

        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Python Debugger: Debug DeepFund",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "args": ["--config", "config/debug_ml.yaml", "--trading-date", "2024-08-03", "--local-db"],
            "cwd": "${fileDirname}"
        },
        {
            "name": "Python Debugger: CostCheck DeepFund",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "args": ["--config", "config/cost_check.yaml", "--trading-date", "2024-08-03", "--local-db"],
            "cwd": "${fileDirname}"
        },
        {
            "name": "Python Debugger: Check API YAML",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "args": ["--config", "config/api.yaml", "--trading-date", "2024-08-03", "--local-db"],
            "cwd": "${fileDirname}"
        }
    ]
}
